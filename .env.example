# AI provider for intent classification: mock | openai | anthropic
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Producer
EVENTS_PER_SECOND=50
ANOMALY_RATE=0.05

# AWS S3 cold storage (leave S3_BUCKET empty to disable - pipeline still runs)
S3_BUCKET=
S3_PREFIX=events
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
